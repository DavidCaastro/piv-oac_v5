# PIV/OAC v5.0 — Local environment configuration
# Copy to .env and fill in real values. Never commit .env.
#
# bootstrap.sh sources this file automatically at startup.
# Variables already exported in the shell take precedence.

# ── Required ────────────────────────────────────────────────────────────────

# Active inference provider: anthropic | openai | ollama
PIV_PROVIDER=anthropic

# Provider API key (only the active provider's key is required)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Optional (defaults shown) ────────────────────────────────────────────────

# Session state directory (relative to repo root)
PIV_SESSION_DIR=.piv

# Vault path for credential references (local dev uses .piv/vault)
PIV_VAULT_PATH=.piv/vault

# Ollama host (only needed when PIV_PROVIDER=ollama)
# OLLAMA_HOST=localhost

# Local model for Tier 2 (passed to --local-model when desired)
# PIV_LOCAL_MODEL=llama3.2:3b

# Webhook secret for HMAC-SHA256 validation (sdk/triggers/webhook.py)
# PIV_WEBHOOK_SECRET=changeme

# GitHub audit token (sdk/triggers/github.py comment posting)
# PIV_AUDIT_TOKEN=ghp_...
