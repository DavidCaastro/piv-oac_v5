{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.2.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "PIV/OAC v5.0 — Per-agent tokens used, phase durations, fragmentation events",
  "editable": false,
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Tokens Used Per Agent (24h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (agent_id) (sum_over_time({service_name=\"piv-oac\"} | json | unwrap tokens_used [24h]))",
          "legendFormat": "{{agent_id}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "SecurityAgent Fragmentations (24h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({service_name=\"piv-oac\", agent_id=\"SecurityAgent\", action=\"fragmentation\"}[24h])",
          "legendFormat": "fragmentations"
        }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [
          {"color": "green", "value": 0},
          {"color": "yellow", "value": 3},
          {"color": "red", "value": 6}
        ]}}
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "CONTEXT_SATURATION Escalations (24h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({service_name=\"piv-oac\", action=\"ESCALATION\", outcome=\"CONTEXT_SATURATION\"}[24h])",
          "legendFormat": "saturations"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Agent Activity — Last 50 Events",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"piv-oac\"} | json | line_format \"{{.agent_id}} | {{.phase}} | {{.action}} | {{.outcome}} | {{.duration_ms}}ms | {{.tokens_used}} tok\"",
          "legendFormat": ""
        }
      ],
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 8 }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["piv-oac", "agents"],
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "title": "PIV/OAC — Agents",
  "uid": "pivoac-agents",
  "version": 1
}
