{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.2.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "PIV/OAC v5.0 — Gate first-pass rates, rejections, circuit breaker events",
  "editable": false,
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Gate 0 First-Pass Rate (24h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"piv-oac\", action=\"gate_verdict\", phase=\"GATE_0\", outcome=\"APPROVED\"}[24h])) / sum(count_over_time({service_name=\"piv-oac\", action=\"gate_verdict\", phase=\"GATE_0\"}[24h]))",
          "legendFormat": "Gate 0 pass rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "steps": [
            {"color": "red", "value": 0},
            {"color": "yellow", "value": 0.7},
            {"color": "green", "value": 0.9}
          ]}
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Gate 2b First-Pass Rate (24h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"piv-oac\", action=\"gate_verdict\", phase=\"GATE_2B\", outcome=\"APPROVED\"}[24h])) / sum(count_over_time({service_name=\"piv-oac\", action=\"gate_verdict\", phase=\"GATE_2B\"}[24h]))",
          "legendFormat": "Gate 2b pass rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "steps": [
            {"color": "red", "value": 0},
            {"color": "yellow", "value": 0.7},
            {"color": "green", "value": 0.9}
          ]}
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Circuit Breaker Activations (24h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({service_name=\"piv-oac\", action=\"circuit_breaker_triggered\"}[24h])",
          "legendFormat": "activations"
        }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [
          {"color": "green", "value": 0},
          {"color": "red", "value": 1}
        ]}}
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Gate Rejections Log",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"piv-oac\", action=\"gate_verdict\", outcome=\"REJECTED\"} | json",
          "legendFormat": ""
        }
      ],
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["piv-oac", "gates"],
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "title": "PIV/OAC — Gates",
  "uid": "pivoac-gates",
  "version": 1
}
